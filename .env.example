# Backend
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/outreach
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
SECRET_KEY=change-me-to-a-random-secret-key-in-production
ENVIRONMENT=development
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:3000

# Google OAuth (REQUIRED for Gmail connection)
# Create a Google Cloud Project, enable Gmail API, create OAuth 2.0 credentials
# Set the redirect URI to: http://localhost:8000/api/v1/gmail/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/gmail/callback

# SMTP (for password reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
